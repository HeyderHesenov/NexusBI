# ─── AI Provider (OpenAI) ───
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ─── Database ───
# Demo/dev: SQLite. Prod: postgresql+asyncpg://user:pass@db:5432/nexusbi
DATABASE_URL=sqlite+aiosqlite:///./nexusbi.db

# ─── Redis (optional in demo) ───
REDIS_URL=redis://localhost:6379/0

# ─── Security ───
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=60
# Fernet key for encrypting datasource connection strings
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# ─── App ───
DEMO_MODE=true
CORS_ORIGINS=http://localhost:5173
